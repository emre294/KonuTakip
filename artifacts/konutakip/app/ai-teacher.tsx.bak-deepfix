          </Text>
        </View>

        {/* Status dot */}
        <View style={styles.statusWrap} accessibilityLabel="ÃƒÆ’Ã†â€™ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¡evrimiÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â§i">
          <View style={[styles.statusDot, { backgroundColor: "#22c55e" }]} />
        </View>
      </Animated.View>

