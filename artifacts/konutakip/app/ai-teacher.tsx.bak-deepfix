</TouchableOpacity>
            <TextInput
              ref={inputRef}
              style={[styles.textInput, { color: colors.foreground }]}
              value={inputText}
              onChangeText={setInputText}
              placeholder="Bir soru sor..."
              placeholderTextColor={colors.mutedForeground}
              multiline
              numberOfLines={1}
              maxLength={500}
              returnKeyType="default"
              blurOnSubmit={false}
              accessibilityLabel="Mesaj yaz"
              accessibilityHint="Sorunuzu yazÃƒÆ’Ã¢â‚¬Å¾Ãƒâ€šÃ‚Â±n ve gÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¶nderin"
              editable={!isLoading}
            />

